# Production .env template for the pilot deploy. Copy to repo-root /.env on the server,
# fill secrets, and keep it OUT of git. Compose reads it (app env_file + db ${VARS}).

# ---- Runtime ----
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000
RELOAD=false
LOG_LEVEL=INFO
# App is reached only via nginx over HTTPS; allow both the hostname and the IP.
CORS_ORIGINS=https://sch21gen.aeza.network,https://77.110.123.227
DISABLE_AUTH=false
STORAGE_DIR=/data/uploads
CONTENT_FACTORY_RUNTIME_DIR=/data/artifacts

# ---- Database (compose service name `db`) ----
POSTGRES_USER=content_user
POSTGRES_PASSWORD=__CHANGE_ME_STRONG__
POSTGRES_DB=content_generator
DATABASE_URL=postgresql://content_user:__CHANGE_ME_STRONG__@db:5432/content_generator
DB_AUTO_CREATE_TABLES=false

# ---- Auth / sessions (HTTPS pilot) ----
JWT_SECRET_KEY=__CHANGE_ME_RANDOM__
AUTH_COOKIE_SECURE=true
JWT_EXPIRATION_HOURS=24
# Registration + reset restricted to the school domain (default already 21-school.ru).
ALLOWED_EMAIL_DOMAINS=21-school.ru
# Pilot: every registrant gets catalog-edit rights. Set back to "user" to require manual promotion.
DEFAULT_REGISTER_ROLE=admin

# ---- Generation durability ----
# Pilot runs with the durable worker OFF (durable STATE via checkpoints; no auto-resume).
WORKFLOW_RECOVERY_ON_STARTUP=true
GENERATION_WORKER_ENABLED=false

# ---- LLM provider (copied from local .env at deploy time) ----
LLM_PROVIDER=polza
POLZA_AI_API_KEY=__FROM_LOCAL_ENV__
POLZA_AI_BASE_URL=https://polza.ai/api/v1
POLZA_AI_MODEL=openai/gpt-5.4-mini
LLM_MODEL_REGISTRY=src/content_factory/config/model_registry.yaml

# ---- Catalog intake pipeline ----
USE_LIVE=true
USE_COUNCIL=true
USE_UP_TEMPLATE_CONSILIUM=true
MODEL_PLAN=openai/gpt-5.4-mini
MODEL_PANEL=openai/gpt-5.4-mini,anthropic/claude-3.5-haiku,google/gemini-2.0-flash-001
MODEL_TEMPLATE_COUNCIL=openai/gpt-5.4-mini

# ---- Email (off for pilot) ----
ENABLE_EMAIL=false
