# Application runtime
# ENVIRONMENT=production switches on the production security gate in
# scripts/production_check.py (fails on auth bypass / insecure cookie / default secret).
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
RELOAD=false
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
DISABLE_AUTH=false
STORAGE_DIR=uploads
CONTENT_FACTORY_RUNTIME_DIR=artifacts
MAX_RESULT_CACHE_SIZE=100

# Database
DATABASE_URL=postgresql://content_user:change_me@localhost:5432/content_generator
DB_ECHO=false
DB_AUTO_CREATE_TABLES=false
DB_MAINTENANCE_BATCH_SIZE=500
LOG_RETENTION_DAYS=1
WORKFLOW_STATE_RETENTION_DAYS=14
PAUSED_SESSION_RETENTION_DAYS=14
ACTIVITY_UPDATE_INTERVAL_SECONDS=60

# Authentication and sessions
JWT_SECRET_KEY=change_me
# AUTH_COOKIE_SECURE=true is required in production (auth cookie sent over HTTPS only).
AUTH_COOKIE_SECURE=false
JWT_EXPIRATION_HOURS=24
MAX_ACTIVE_SESSIONS_PER_USER=5
SESSION_INACTIVITY_TIMEOUT_HOURS=24
MAX_FAILED_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30
ALLOWED_EMAIL_DOMAIN=21-school.ru

# LLM provider gateway
LLM_MODEL_REGISTRY=src/content_factory/config/model_registry.yaml
# LLM provider preference: polza | openai | deepseek | azure | gigachat
LLM_PROVIDER=polza

# Polza AI (default text LLM gateway, OpenAI-compatible API)
POLZA_AI_API_KEY=
POLZA_AI_BASE_URL=https://polza.ai/api/v1
POLZA_AI_MODEL=openai/gpt-5.4-mini
POLZA_AI_TEMPERATURE=0.4

# OpenAI (optional direct provider; ASR still uses OPENAI_API_KEY for Whisper-compatible transcription)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TEMPERATURE=0.4

# DeepSeek (OpenAI-compatible API)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TEMPERATURE=0.3

# GigaChat (OAuth credentials from Sber console)
GIGACHAT_CREDENTIALS=
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-2-Pro
GIGACHAT_TEMPERATURE=0.3
GIGACHAT_VERIFY_SSL_CERTS=true

# Optional role-specific model overrides. Empty values fall back to model_registry.yaml.
POLZA_AI_PLANNER_MODEL=
POLZA_AI_THEORY_MODEL=
POLZA_AI_PRACTICE_MODEL=
POLZA_AI_CRITIC_MODEL=
POLZA_AI_TRANSLATOR_MODEL=
OPENAI_PLANNER_MODEL=
OPENAI_THEORY_MODEL=
OPENAI_PRACTICE_MODEL=
OPENAI_CRITIC_MODEL=
OPENAI_TRANSLATOR_MODEL=
DEEPSEEK_PLANNER_MODEL=
DEEPSEEK_THEORY_MODEL=
DEEPSEEK_PRACTICE_MODEL=
DEEPSEEK_CRITIC_MODEL=
DEEPSEEK_TRANSLATOR_MODEL=
GIGACHAT_PLANNER_MODEL=
GIGACHAT_THEORY_MODEL=
GIGACHAT_PRACTICE_MODEL=
GIGACHAT_CRITIC_MODEL=
GIGACHAT_TRANSLATOR_MODEL=

LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1.0
LLM_TIMEOUT_SECONDS=120
LLM_BUDGET_USD_PER_ROLE=
LLM_BUDGET_DB_ENABLED=true
LITELLM_LOCAL_MODEL_COST_MAP=True
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL=3600
LLM_CACHE_MAX_SIZE=1000
LLM_BATCHING_ENABLED=true
LLM_BATCH_MAX_WORKERS=10
REDIS_URL=

# Observability
# Empty keeps traces in result JSON only. Supported optional exporters: otel,langfuse
OBSERVABILITY_EXPORTERS=
OTEL_ENABLED=false
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Azure OpenAI (optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_TEMPERATURE=0.3

# Methodology gates
# observe: log issues only; approval: pause on critical/human review; strict: fail on critical
METHODOLOGY_GATE_MODE=observe
# Empty/off disables human checkpoints. Use all or comma-separated: annotation,theory,practice,quality,evaluation
METHODOLOGY_HUMAN_CHECKPOINTS=
# Optional Pydantic AI parser for ambiguous methodology chat commands. Deterministic parser is used by default.
METHODOLOGY_ASSISTANT_PYDANTIC_AI=false
METHODOLOGY_ASSISTANT_MODEL=

# Email
ENABLE_EMAIL=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Upload limits
MAX_FILES_COUNT=20
MAX_FILE_SIZE_BYTES=10485760
MAX_TOTAL_FILES_SIZE_BYTES=104857600

# Executors
DB_EXECUTOR_WORKERS=10
LOG_EXECUTOR_WORKERS=4
VALIDATION_EXECUTOR_WORKERS=8
GENERAL_EXECUTOR_WORKERS=4

# Mermaid diagrams
# none: keep ```mermaid``` blocks and render them in UI/GitHub/GitLab without PNG export
# local: export PNG via local Mermaid CLI (`mmdc`)
# kroki: export PNG via https://kroki.io
# auto: try local CLI first, then Kroki
MERMAID_EXPORT_MODE=none
MERMAID_EXPORT_MAX_DIAGRAMS=10
MERMAID_CLI_PATH=
MERMAID_LOCAL_TIMEOUT_SECONDS=8
MERMAID_KROKI_TIMEOUT_SECONDS=4

# Subtitles / media pipeline
SUBTITLES_DEBUG_LOG=false
MAX_VIDEO_SIZE_BYTES=524288000
TRANSLATE_BATCH_SIZE=20
SUBTITLE_CONTEXT_WINDOW=3
# Optional provider-specific overrides. If empty, subtitle translation uses the active LLM_PROVIDER default model.
TRANSLATE_SUBTITLES_MODEL=
POLZA_AI_TRANSLATE_SUBTITLES_MODEL=
DEEPSEEK_TRANSLATE_SUBTITLES_MODEL=
GIGACHAT_TRANSLATE_SUBTITLES_MODEL=
WHISPER_ASR_MODEL=whisper-1
VIDEO_ENCODER=libx264
X264_PRESET=medium
X264_CRF=23
NVENC_PRESET=p4
NVENC_CQ=23
AAC_BITRATE=192k
VIDEO_MAX_CONCURRENT_JOBS=2

# =====================================================================
# NOTE (transitional): the blocks below use the ORIGINAL per-module
# variable names so a single root .env can feed all three modules during
# the merge. Phase 2 introduces one pydantic-settings Settings and may
# rename/namespace some of these. Shared: POLZA_AI_API_KEY (all modules).
# =====================================================================

# ---- Audit module (ex-Proverka / content-audit) ----
# LLM: reuses POLZA_AI_API_KEY above (active provider). The audit code also accepts
# OPENROUTER_API_KEY / OPEN_ROUTER_API_KEY as alternate-provider fallbacks if set.
# Legacy audit web UI basic-auth (to be replaced by unified JWT auth in Phase 5)
AUTH_USERNAME=
AUTH_PASSWORD=

# ---- Catalog module (ex-Spravochnik) ----
# LLM model selection for the intake pipeline / councils
MODEL_PLAN=openai/gpt-5.4-mini
MODEL_SEARCH=perplexity/sonar
MODEL_PANEL=openai/gpt-5.4-mini,anthropic/claude-3.5-haiku,google/gemini-2.0-flash-001
MODEL_TEMPLATE_COUNCIL=openai/gpt-5.4-mini
MODEL_TEMPLATE_COUNCIL_MAX_TOKENS=
POLZA_AI_TIMEOUT_SECONDS=120
# Pipeline stage toggles
USE_LIVE=true
USE_COUNCIL=true
USE_UP_TEMPLATE_CONSILIUM=true
# Confidence / matching thresholds
TAU_CONFIDENCE=0.75
TAU_EDGE_ACCEPT=0.6
MIN_SOURCES=2
FUZZY_MATCH_MIN=90
COUNCIL_AGREE_OK=0.67
UP_TEMPLATE_COUNCIL_TIMEOUT_SECONDS=120

# ---- Deployment / ops (optional; keep out of app config) ----
# DEPLOY_HOST=
# DEPLOY_USER=
# DEPLOY_PASSWORD=
# MBK_DEPLOY_HOST=
# MBK_DEPLOY_USER=
# MBK_DEPLOY_PASSWORD=
